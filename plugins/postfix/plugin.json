{
  "id": "postfix",
  "name": "Postfix (メールサーバー)",
  "version": "0.1.0",
  "author": "RT2231",
  "description": "代表的なMTA(メール転送エージェント)であるPostfixの状態確認・キュー確認・設定チェックを管理します。",
  "service": {
    "systemdUnit": "postfix.service",
    "configPath": "/etc/postfix/main.cf"
  },
  "actions": [
    { "id": "status", "label": "サービス状態", "cli": ["systemctl", "status", "postfix.service", "--no-pager"], "privileged": false },
    { "id": "config-test", "label": "設定ファイルの文法チェック", "cli": ["postfix", "check"], "privileged": true },
    { "id": "mailq", "label": "メールキューの確認", "cli": ["mailq"], "privileged": false },
    { "id": "flush-queue", "label": "キューの配送を強制実行", "cli": ["postfix", "flush"], "privileged": true },
    { "id": "start", "label": "起動", "cli": ["systemctl", "start", "postfix.service"], "privileged": true },
    { "id": "stop", "label": "停止", "cli": ["systemctl", "stop", "postfix.service"], "privileged": true },
    { "id": "restart", "label": "再起動", "cli": ["systemctl", "restart", "postfix.service"], "privileged": true },
    { "id": "reload", "label": "設定を再読込(無停止)", "cli": ["systemctl", "reload", "postfix.service"], "privileged": true },
    { "id": "enable", "label": "自動起動を有効化", "cli": ["systemctl", "enable", "postfix.service"], "privileged": true },
    { "id": "disable", "label": "自動起動を無効化", "cli": ["systemctl", "disable", "postfix.service"], "privileged": true }
  ],
  "docs": "docs.md"
}
