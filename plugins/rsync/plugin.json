{
  "id": "rsync",
  "name": "rsync (ファイル同期デーモン)",
  "version": "0.1.0",
  "author": "RT2231",
  "description": "rsyncをデーモンモードで動かし、ネットワーク越しのファイル同期・バックアップの受け口として使うための状態確認・起動停止を管理します。",
  "service": {
    "systemdUnit": "rsync.service",
    "configPath": "/etc/rsyncd.conf"
  },
  "actions": [
    { "id": "status", "label": "サービス状態", "cli": ["systemctl", "status", "rsync.service", "--no-pager"], "privileged": false },
    { "id": "version", "label": "バージョン確認", "cli": ["rsync", "--version"], "privileged": false },
    { "id": "start", "label": "起動", "cli": ["systemctl", "start", "rsync.service"], "privileged": true },
    { "id": "stop", "label": "停止", "cli": ["systemctl", "stop", "rsync.service"], "privileged": true },
    { "id": "restart", "label": "再起動", "cli": ["systemctl", "restart", "rsync.service"], "privileged": true },
    { "id": "enable", "label": "自動起動を有効化", "cli": ["systemctl", "enable", "rsync.service"], "privileged": true },
    { "id": "disable", "label": "自動起動を無効化", "cli": ["systemctl", "disable", "rsync.service"], "privileged": true }
  ],
  "docs": "docs.md"
}
