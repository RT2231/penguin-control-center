{
  "id": "samba",
  "name": "Samba (ファイル共有)",
  "version": "0.1.0",
  "author": "RT2231",
  "description": "Windows/Mac/Linux間でファイルを共有するSambaサーバー(smbd)の状態確認・起動停止・設定を管理します。",
  "service": {
    "systemdUnit": "smbd.service",
    "configPath": "/etc/samba/smb.conf"
  },
  "actions": [
    {
      "id": "status",
      "label": "サービス状態",
      "cli": [
        "systemctl",
        "status",
        "smbd.service",
        "--no-pager"
      ],
      "privileged": false
    },
    {
      "id": "config-test",
      "label": "設定ファイルの文法チェック",
      "cli": [
        "testparm",
        "-s"
      ],
      "privileged": false
    },
    {
      "id": "shares-list",
      "label": "共有一覧(ローカルから確認)",
      "cli": [
        "smbclient",
        "-L",
        "localhost",
        "-N"
      ],
      "privileged": false
    },
    {
      "id": "start",
      "label": "起動",
      "cli": [
        "systemctl",
        "start",
        "smbd.service"
      ],
      "privileged": true
    },
    {
      "id": "stop",
      "label": "停止",
      "cli": [
        "systemctl",
        "stop",
        "smbd.service"
      ],
      "privileged": true
    },
    {
      "id": "restart",
      "label": "再起動",
      "cli": [
        "systemctl",
        "restart",
        "smbd.service"
      ],
      "privileged": true
    },
    {
      "id": "enable",
      "label": "自動起動を有効化",
      "cli": [
        "systemctl",
        "enable",
        "smbd.service"
      ],
      "privileged": true
    },
    {
      "id": "disable",
      "label": "自動起動を無効化",
      "cli": [
        "systemctl",
        "disable",
        "smbd.service"
      ],
      "privileged": true
    }
  ],
  "docs": "docs.md"
}
